          "content": {
            "size": 2446,
            "mimeType": "text/css; charset=utf-8",
            "compression": 1676,
            "text": "/*\n * UTILITY\n */\n\n#site-nav, #footer {\n    display:none;\n}\n\n\n/*\n * HERO\n */\n\n#hero {\n    border-top: 10px solid #3e8dd0;\n    padding: 130px 0;\n}\n\n#preheader {\n    color: #3e8dd0;\n    margin-bottom: 0px;\n    font-size: 3.0em;\n    font-family: 'Courgette', cursive;\n}\n\n#header {\n    color: #3e8dd0;\n    margin: 2px 0px;\n    font-size: 4.5em;\n    font-family: 'Raleway', sans-serif;\n    text-transform: uppercase;\n}\n\n#postheader {\n    color: #c0c0c0;\n    margin: 0px;\n    font-family: 'Raleway', sans-serif;\n    font-size: 2.0em;\n}\n\n#subhero {\n    background: #c44b4b;\n    color: #fff;\n    padding: 40px 0;\n    font-family: 'Courgette', cursive;\n    font-size: 2.3em;\n}\n\n#video {\n    background: #3e8dd0;\n    color: #efefef;\n    padding: 20px;\n    font-family: 'Courgette', cursive;\n    font-size: 2.3em;\n}\n\n#testimonials {\n    margin: 40px 0;\n}\n\n.benefit-row {\n    margin-top: 80px;\n}\n.benefit-row:last-child{\n    margin-bottom: 80px;\n}\n\nli {\n    font-size: 1.3em;\n}\n\n.screenshot {\n    border: 5px solid #007FFF;\n}\n\n#guarantee {\n    padding: 40px;\n}\n\n#story h2 {\n    font-family: 'Courgette', cursive;\n}\n\n#fine-print h3 {\n    font-family: 'Courgette', cursive;\n}\n\n.buy-now a.gumroad-button {\n    margin: 60px 0;\n    font-size: 1.5em !important;\n\n    padding: 5px 50px !important;\n    color: white !important;\n    background-image: none !important;\n\n    background: #3498db !important;\n    background-image: -webkit-linear-gradient(top, #3498db, #2980b9) !important;\n    background-image: -moz-linear-gradient(top, #3498db, #2980b9) !important;\n    background-image: -ms-linear-gradient(top, #3498db, #2980b9) !important;\n    background-image: -o-linear-gradient(top, #3498db, #2980b9) !important;\n    background-image: linear-gradient(to bottom, #3498db, #2980b9) !important;\n}\n.buy-now .gumroad-button-logo {\n    display: none !important;\n}\n.buy-now .cta-subtext {\n    margin: -40px 0 40px;\n    display: block;\n}\n\n#footer-content {\n    padding: 20px;\n}\n\n/*\n * Bounce Modal\n */\n\n.modal h4 {\n    font-family: 'Courgette', cursive;\n}\n\n.modal p {\n  font-size: 1.5em;\n  font-family: 'Raleway', sans-serif;\n}\n\n.modal .lead {\n  text-transform: uppercase;\n  font-size: 5.0em;\n}\n\n.modal #modal-countdown {\n    font-family: \"Helvetica Neue\",Helvetica,Arial,sans-serif;\n}\n\n.modal .modal-footer {\n  text-align: center;\n}\n\n.modal .buy-now a.gumroad-button {\n    margin: 20px 0;\n}\n.modal .buy-now .cta-subtext {\n    margin: -10px 0 10px;\n    display: block;\n}\n"
          },
          "headersSize": 992,
          "bodySize": 770,
